# ── Metriplex Node Configuration ────────────────────────
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a git

# ── Relayer EVM ─────────────────────────────────────────
# Clave privada de la billetera que desplegó el contrato en Ethereum
# Obtenerla desde: Brave/MetaMask → Cuenta → Exportar clave privada
RELAYER_EVM_KEY=tu_clave_privada_de_64_chars_hex

# ── Vault / Bóveda ──────────────────────────────────────
# Contraseña del keystore cifrado de la Bóveda
VAULT_PASSWORD=tu_contraseña_segura

# Ruta al archivo keystore de la Bóveda (generado por el relayer)
VAULT_KEYSTORE=vault_keystore.json

# ── Red Ethereum ─────────────────────────────────────────
# RPC de Sepolia (testnet) o mainnet
# Opciones gratuitas: https://sepolia.drpc.org | https://1rpc.io/sepolia
WEB3_RPC=https://sepolia.drpc.org

# ── Nodo Metriplex ───────────────────────────────────────
MXP_NODE_URL=http://localhost:8000
